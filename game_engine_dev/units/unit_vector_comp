#!/bin/bash

# Define the include path for the compiler
INC="-I../ -I../misc -I../data_io"

# Compile objects (Adding the path to files in misc)
g++ $INC -c ../misc/str_mng.cpp -o str_mng.o
g++ $INC -c ../misc/bit_array.cpp -o bit_array.o
g++ $INC -c ../data_io/city_flags.cpp -o city_flags.o
g++ $INC -c ../data_io/tech_data.cpp -o tech_data.o
g++ $INC -c ../data_io/resource_data.cpp -o resource_data.o
g++ $INC -c ../data_io/building_data.cpp -o building_data.o
g++ $INC -c ../data_io/unit_data.cpp -o unit_data.o
g++ $INC -c unit_vector.cpp -o unit_vector.o
g++ $INC -c unit_vector_tester.cpp -o unit_vector_tester.o

# Link everything into the final tester
g++ -o unit_vector_tester \
    str_mng.o \
    bit_array.o \
    city_flags.o \
    tech_data.o \
    resource_data.o \
    building_data.o \
    unit_data.o \
    unit_vector.o \
    unit_vector_tester.o

# Clean up
rm \
    str_mng.o \
    bit_array.o \
    city_flags.o \
    tech_data.o \
    resource_data.o \
    building_data.o \
    unit_data.o \
    unit_vector.o \
    unit_vector_tester.o