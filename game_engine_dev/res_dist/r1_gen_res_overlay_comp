g++ $CXXFLAGS $INC -c ../adv_map_gen/p1_gen_climate.cpp -o p1_gen_climate.o
g++ $CXXFLAGS $INC -c r1_gen_res_overlay_tester.cpp -o r1_gen_res_overlay_tester.o

g++ $CXXFLAGS -o r1_gen_res_overlay_tester \
    runtime_static_loader.o \
    res_statics.o \
    resource_placement.o \
    r1_adj_res_place.o \
    r1_gen_res_overlay.o \
    map_terrain_validate.o \
    generator_constants.o \
    perlin_noise.o \
    whiteboard.o \
    p1_gen_outline.o \
    p1_gen_land_depth.o \
    p1_gen_noise_perlin.o \
    p1_adj_outline_fill.o \
    p1_gen_shaped_outline.o \
    p1_gen_river_pts.o \
    p1_gen_river_sectors.o \
    p1_gen_river_network.o \
    p1_gen_river_lines.o \
    p1_adj_river_lakes.o \
    p1_adj_river_inlets.o \
    p1_gen_watershed_mountains.o \
    p1_gen_watershed_mountain_line_sets.o \
    p1_gen_distance_to_river.o \
    p1_gen_nearness_to_watershed_mtn.o \
    p1_adj_land_altitude.o \
    p1_adj_ensure_coasts.o \
    p1_adj_ensure_seas.o \
    p1_adj_ensure_river_valleys.o \
    p1_adj_ensure_mtn_foothills.o \
    p1_tester_chain15.o \
    p1_gen_climate.o \
    r1_gen_res_overlay_tester.o \
    -ldl \
    $LIB_SO \
    -Wl,-rpath,'$ORIGIN/../data_io' -lm

rm runtime_static_loader.o res_statics.o resource_placement.o r1_adj_res_place.o \
    r1_gen_res_overlay.o map_terrain_validate.o generator_constants.o \
    perlin_noise.o whiteboard.o p1_gen_outline.o p1_gen_land_depth.o \
    p1_gen_noise_perlin.o p1_adj_outline_fill.o p1_gen_shaped_outline.o \
    p1_gen_river_pts.o p1_gen_river_sectors.o p1_gen_river_network.o \
    p1_gen_river_lines.o p1_adj_river_lakes.o p1_adj_river_inlets.o \
    p1_gen_watershed_mountains.o p1_gen_watershed_mountain_line_sets.o \
    p1_gen_distance_to_river.o p1_gen_nearness_to_watershed_mtn.o \
    p1_adj_land_altitude.o p1_adj_ensure_coasts.o p1_adj_ensure_seas.o \
    p1_adj_ensure_river_valleys.o p1_adj_ensure_mtn_foothills.o \
