#!/bin/bash

INC="-I../ -I../misc -I../adv_map_gen -I../map_loader -I../data_io -I../static_state"
CXXFLAGS="-std=c++17"
LIB_SO="../data_io/runtime_static_loader_lib.so"

if [ ! -f "$LIB_SO" ]; then
    echo "missing $LIB_SO - run ../data_io/runtime_static_loader_lib_comp first"
    exit 1
fi

MAP="../map_loader/map_terrain_validate.cpp"
GEN="../adv_map_gen/generator_constants.cpp"
PRN="../adv_map_gen/perlin_noise.cpp"
WBD="../adv_map_gen/whiteboard.cpp"

g++ $CXXFLAGS $INC -c ../data_io/runtime_static_loader.cpp -o runtime_static_loader.o
g++ $CXXFLAGS $INC -c res_statics.cpp -o res_statics.o
g++ $CXXFLAGS $INC -c resource_placement.cpp -o resource_placement.o
g++ $CXXFLAGS $INC -c r1_adj_res_place.cpp -o r1_adj_res_place.o
g++ $CXXFLAGS $INC -c r1_gen_res_overlay.cpp -o r1_gen_res_overlay.o
g++ $CXXFLAGS $INC -c $MAP -o map_terrain_validate.o
g++ $CXXFLAGS $INC -c $GEN -o generator_constants.o
g++ $CXXFLAGS $INC -c $PRN -o perlin_noise.o
g++ $CXXFLAGS $INC -c $WBD -o whiteboard.o
g++ $CXXFLAGS $INC -c ../adv_map_gen/p1_gen_outline.cpp -o p1_gen_outline.o
g++ $CXXFLAGS $INC -c ../adv_map_gen/p1_gen_land_depth.cpp -o p1_gen_land_depth.o
g++ $CXXFLAGS $INC -c ../adv_map_gen/p1_gen_noise_perlin.cpp -o p1_gen_noise_perlin.o
g++ $CXXFLAGS $INC -c ../adv_map_gen/p1_adj_outline_fill.cpp -o p1_adj_outline_fill.o
g++ $CXXFLAGS $INC -c ../adv_map_gen/p1_gen_shaped_outline.cpp -o p1_gen_shaped_outline.o
g++ $CXXFLAGS $INC -c ../adv_map_gen/p1_gen_river_pts.cpp -o p1_gen_river_pts.o
g++ $CXXFLAGS $INC -c ../adv_map_gen/p1_gen_river_sectors.cpp -o p1_gen_river_sectors.o
