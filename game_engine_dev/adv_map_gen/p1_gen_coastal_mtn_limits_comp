#!/bin/bash

set -e

ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT"

source p1_build_core_map_objs.sh

INC="-I. -I.. -I../map_loader -I../static_state -I../misc"

g++ -std=c++11 $INC -c p1_gen_coastal_mtn_limits_tester.cpp -o p1_gen_coastal_mtn_limits_tester.o

g++ -std=c++11 -o p1_gen_coastal_mtn_limits_tester \
    $CORE_MAP_OBJS \
    p1_gen_coastal_mtn_limits_tester.o -lm

rm $CORE_MAP_OBJS p1_gen_coastal_mtn_limits_tester.o
